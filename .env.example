# ── KisanCredit AI  —  Environment Variables ──────────────────
# Copy this file to .env and fill in your values.
# The .env file is gitignored and never committed.

# Flask secret key (change this in production!)
SECRET_KEY=kisancredit-change-me-in-production

# Groq API key for the LLM-powered chatbot (optional)
# Leave blank to use the built-in rule-based chatbot fallback.
# Get a free key at: https://console.groq.com
GROQ_API_KEY=
